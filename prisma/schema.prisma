
generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgres"
    url = env("DATABASE_URL")
}

model User{
    id String @id @default(cuid())
    email String @unique
    username String @unique
    firstname String? 
    lastname String?
    password String
    companyname String
    role Role @default(ADMIN)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}

enum Role {
    ADMIN           // Main user/account creator
    HANDLER         // User representative
    COORDINATOR     // Kibou Systems provided customer support assistant
}